# =============================================================
# Private / secret
# =============================================================
# TUF signing keys — never commit private keys
Keys/

# =============================================================
# Build output
# =============================================================
# Nuitka compiled output
dist/
build/
*.dist-info/
nuitka-crash-report.xml
# Generated installers
installers/

# =============================================================
# TUF release artifacts — hosted on GitHub Releases, not in git
# =============================================================
# large .tar.gz and .patch bundles
my-tuf-repo/targets/
# runtime tufup client dirs — created automatically by updater.py
/metadata/
/targets/

# =============================================================
# Python
# =============================================================
venv/
.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.eggs/

# =============================================================
# Runtime / user-specific files
# =============================================================
# auto-generated at runtime
resolution_cache.json
# user settings — each machine configures their own
settings.json
crash.log
.camera.lock

# =============================================================
# Large binary assets (download separately / user-supplied)
# =============================================================
# ONNX model files
models/
# Face databases — ignore photos, preserve directory structure via .gitkeep
# All files under faces_db/ are ignored...
faces_db/**/*
# ...except directories themselves and .gitkeep placeholder files
!faces_db/**/
!faces_db/**/.gitkeep

# =============================================================
# Cache & temp
# =============================================================
cache/
*.tmp
*.temp

# =============================================================
# IDE / OS
# =============================================================
# keep .vscode/launch.json etc, ignore personal settings
.vscode/settings.json
.idea/
*.swp
*~
Thumbs.db
desktop.ini
.DS_Store
Upload_Keys.txt
